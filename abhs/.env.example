# ─── Database ──────────────────────────────────────────────
# Path to SQLite database file (relative to abhs/ or absolute)
CRM_DB_PATH=./data/abhs.db

# ─── Admin Auth ───────────────────────────────────────────
# CHANGE BOTH OF THESE before deploying to production!
# Generate with: openssl rand -base64 24
ADMIN_PASSWORD=change-me-to-something-strong
# Generate with: openssl rand -base64 32
ADMIN_SECRET=change-me-to-a-random-secret

# ─── Square Bookings API ─────────────────────────────────
# 1. Go to https://developer.squareup.com/apps
# 2. Create or select your application
# 3. Copy the Access Token (sandbox for testing, production for live)
# 4. Find Location ID: Square Dashboard → Settings → Locations
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-location-id
SQUARE_ENVIRONMENT=sandbox

# ─── Instagram Gallery ───────────────────────────────────
# 1. Create a Meta Developer app at developers.facebook.com
# 2. Add "Instagram API with Instagram Login" product
# 3. Generate a long-lived access token (lasts 60 days)
INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# ─── SMS Notifications (optional) ────────────────────────
# Email-to-SMS via carrier gateway. Sends text on new intake.
# NOTIFY_PHONE=5551234567
# SMS_GATEWAY=txt.att.net
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
